<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>글쓰기 포털</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="center-page">

  <div class="portal-card">
    <div class="brand-mark">W</div>
    <h1 class="portal-title">Writing Exam Portal</h1>
    <p class="portal-subtitle">이름과 학번을 입력하세요.</p>

    <form method="POST" action="/login" class="portal-form">
      <input name="name" placeholder="이름" required>
      <input name="id" placeholder="학번" required>
      <button type="submit" class="primary-btn">들어가기</button>
    </form>
  </div>

</body>
</html>