<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<title><%= title %></title>
<link rel="stylesheet" href="/style.css">
</head>
<body>
  <h1><%= title %></h1>
  <textarea id="editor" placeholder="여기에 글 작성"></textarea>
  <div>
    <span id="charCount">0</span> 글자
    <span id="timer">00:00</span>
  </div>
  <button id="saveBtn">임시저장</button>
  <button id="submitBtn">제출</button>

<script src="/script.js"></script>
</body>
</html>