<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>제출 결과</title>
  <link rel="stylesheet" href="/style.css?v=50">
</head>
<body class="app-page">
<div class="app-shell">

  <div class="top-card">
    <div>
      <div class="small-label">작성자</div>
      <h1 class="page-title"><%= studentName %></h1>
      <div class="meta-line"><%= studentClass ? "분반: " + studentClass : "" %></div>
    </div>
  </div>

  <div class="panel-card">
    <h2 class="section-title">제출한 글</h2>
    <textarea readonly rows="14"><%= text %></textarea>
  </div>

  <div class="panel-card">
    <h2 class="section-title">교수자 코멘트</h2>
    <textarea readonly rows="8"><%= comment || "아직 코멘트가 없습니다." %></textarea>
  </div>

</div>
</body>
</html>