<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>관리자 로그인</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="center-page">

  <div class="portal-card">
    <div class="brand-mark">A</div>
    <h1 class="portal-title">Admin Portal</h1>
    <p class="portal-subtitle">관리자 아이디와 비밀번호를 입력하세요.</p>

    <form method="POST" action="/admin-login" class="portal-form">
      <input name="id" placeholder="관리자 ID" required>
      <input name="password" type="password" placeholder="비밀번호" required>
      <button type="submit" class="primary-btn">로그인</button>
    </form>

    <a class="text-link" href="/login">학생 로그인으로 이동</a>
  </div>

</body>
</html>