<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>글 작성</title>
  <link rel="stylesheet" href="/style.css?v=50">
</head>
<body class="app-page">
<div class="app-shell">

  <div class="top-card">
    <div class="writer-card-grid">
      <div>
        <div class="small-label">작성자</div>
        <h1 class="page-title"><%= studentName %></h1>
        <div class="meta-line"><%= studentClass ? "분반: " + studentClass : "" %></div>
      </div>

      <div class="writer-notice">
        <h3>유의사항</h3>
        <p>
          • 복사 및 붙여넣기 불가 / • 화면 이탈 시 입력 불가 / • 교수자 승인 후 작성 가능
        </p>
      </div>
    </div>
  </div>

  <div class="panel-card">
    <h2 class="section-title">주제</h2>
    <div class="topic-box"><%= topic %></div>

    <div class="count-row">
      <div>
        공백 포함 <strong><span id="withSpace">0</span></strong> /
        공백 제외 <strong><span id="withoutSpace">0</span></strong> /
        최소 글자수 <strong><%= minChars %></strong>
      </div>

      <div class="timer-box">
        남은 시간 <strong id="timeText">--:--</strong>
      </div>
    </div>

    <div id="lockBanner" class="lock-banner" style="display:none;">
      입력창이 차단되었습니다. 교수자 승인 후 다시 작성할 수 있습니다.
    </div>

    <textarea id="editor"><%= text || "" %></textarea>

    <div class="action-row" style="margin-top:16px;">
      <button type="button" class="btn-outline" onclick="manualSave()">임시저장</button>
      <button type="button" class="btn-outline" onclick="downloadTxt()">다운로드(txt)</button>
      <button type="button" class="btn-main" onclick="submitWriting()">제출</button>
    </div>
  </div>

</div>

<div id="modalOverlay" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div class="modal-title" id="modalTitle"></div>
    <div class="modal-text" id="modalText"></div>
    <div class="action-row" id="modalActions" style="justify-content:center;"></div>
  </div>
</div>

<script>
  // 1. 서버 데이터 주입 (변수명 꼬임 방지를 위해 새로 정의)
  const _sId = "<%= id %>";
  const _endTime = <%= endTime ? Number(endTime) : (Date.now() + 3600000) %>;
  
  // 2. 화면 요소 강제 매칭
  const _editor = document.getElementById("editor");
  const _timer = document.getElementById("timeText") || document.getElementById("timer");
  const _banner = document.getElementById("lockBanner");

  function forceUpdate() {
    const now = Date.now();
    const diff = _endTime - now;

    // 타이머 그리기
    if (_timer) {
      if (diff <= 0) {
        _timer.innerText = "00:00";
        if (_editor) _editor.disabled = true;
      } else {
        const m = String(Math.floor(diff / 60000)).padStart(2, "0");
        const s = String(Math.floor((diff % 60000) / 1000)).padStart(2, "0");
        _timer.innerText = m + ":" + s;
      }
    }

    // ★ 핵심: 입력창 무조건 열기 (교수자 승인 상태와 무관하게 일단 엽니다)
    if (_editor && diff > 0) {
        _editor.disabled = false;
        _editor.readOnly = false;
        _editor.style.backgroundColor = "#fff"; // 배경색도 흰색으로 강제
    }
    
    // 배너 숨기기
    if (_banner) _banner.style.display = "none";
  }

  // 1초마다 무한 반복
  setInterval(forceUpdate, 1000);
  // 로드 즉시 실행
  window.onload = forceUpdate;
</script>
</body>

<script>
  // 0.5초마다 화면의 모든 textarea와 input을 강제로 활성화
  setInterval(() => {
    const allInputs = document.querySelectorAll('textarea, input');
    allInputs.forEach(el => {
      el.disabled = false;
      el.readOnly = false;
      el.style.backgroundColor = "white";
    });
    
    // 잠금 배너나 모달이 있다면 강제로 숨김
    const overlays = document.querySelectorAll('[id*="lock"], [id*="modal"], [id*="Overlay"]');
    overlays.forEach(el => {
      if(el.id !== 'editor') el.style.display = 'none';
    });
  }, 500);
</script>
</html>