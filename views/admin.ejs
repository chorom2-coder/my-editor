<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>관리자 페이지</title>
<link rel="stylesheet" href="/style.css">
</head>

<body>

<h1>관리자 페이지</h1>

<p>로그인 사용자: <%= adminName %></p>

<p>승인 요청: <%= approvalCount || 0 %> 명</p>

<hr>

<h2>분반 설정</h2>

<form method="POST" action="/startClass">
<input type="text" name="className" placeholder="분반 입력">
<button type="submit">시작</button>
</form>

<form method="POST" action="/stopClass">
<input type="text" name="className" placeholder="분반 입력">
<button type="submit">종료</button>
</form>

<hr>

<h2>학생 목록</h2>

<table border="1" cellpadding="8">

<tr>
<th>이름</th>
<th>학번</th>
<th>분반</th>
<th>상태</th>
<th>작업</th>
</tr>

<% students.forEach(function(student){ %>

<tr>

<td><%= student.name %></td>

<td><%= student.studentId %></td>

<td><%= student.class %></td>

<td>

<% const sub = submissions[student.studentId] || {} %>

<% if(sub.submitted){ %>
제출 완료
<% } else { %>
미제출
<% } %>

<% if(sub.approvalRequested){ %>
 | 승인 요청
<% } %>

</td>

<td>

<a href="/admin/student/<%= student.studentId %>">열기</a>

</td>

</tr>

<% }) %>

</table>

<br>

<a href="/logout">로그아웃</a>

</body>
</html>