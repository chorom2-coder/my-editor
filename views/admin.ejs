<a href="/download">
<button>CSV 다운로드</button>
</a>

<h1>관리자</h1>

<h2>주제 설정</h2>

<form method="POST" action="/config">

주제  
<textarea name="topic"><%= config.topic %></textarea>

최소 글자수  
<input name="minChars" value="<%= config.minChars %>">

<button type="submit">저장</button>

</form>

<hr>

<h2>제출 글</h2>

<% submissions.forEach(s=>{ %>

<div>

<b><%= s.name %></b> (<%= s.studentId %>)  

<pre><%= s.content %></pre>

<form method="POST" action="/comment">

<input type="hidden" name="studentId" value="<%= s.studentId %>">

<textarea name="comment"><%= s.comment %></textarea>

<button type="submit">코멘트 저장</button>

</form>

</div>

<hr>

<% }) %>